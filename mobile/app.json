{
  "expo": {
    "name": "EduRank",
    "slug": "edurank",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "scheme": "edurank",
    "splash": {
      "backgroundColor": "#378ADD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.edurank.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#378ADD"
      },
      "package": "com.edurank.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
